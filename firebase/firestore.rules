rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && request.auth.token.admin == true; }
    function isModerator() { return signedIn() && request.auth.token.moderator == true; }
    function isSupport() { return signedIn() && request.auth.token.support == true; }
    function isReadonly() { return isAdmin() || isModerator() || isSupport() || (signedIn() && request.auth.token.readonly == true); }
    function isAdminOrModerator() { return isAdmin() || isModerator(); }
    function isMinSupport() { return isAdminOrModerator() || isSupport(); }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }

    function bookingRef(bookingId) {
      return /databases/$(database)/documents/bookings/$(bookingId);
    }
    function bookingDoc(bookingId) { return get(bookingRef(bookingId)); }
    function bookingExists(bookingId) { return exists(bookingRef(bookingId)); }
    function bookingData(bookingId) { return bookingDoc(bookingId).data; }

    function isBookingParticipant(bookingId) {
      return signedIn()
        && bookingExists(bookingId)
        && (bookingData(bookingId).customerId == request.auth.uid
            || bookingData(bookingId).providerId == request.auth.uid);
    }

    /// Phone sharing is unlocked when booking status is accepted, in_progress, or done.
    function bookingAccessible(bookingId) {
      return bookingExists(bookingId)
        && bookingData(bookingId).status in ["accepted", "in_progress", "done"];
    }

    // ---------- USERS ----------
    // Any signed-in user may read profiles (needed to display provider names/avatars
    // on service cards, chat tiles, etc.). Writes remain self-only AND must not
    // touch security-sensitive fields (phoneE164, email, id). Those fields are
    // server-managed (Cloud Functions via admin SDK bypass these rules).
    // `createdAt` is intentionally not checked: Dart DateTime↔Timestamp round-trip
    // loses nanosecond precision, so equality always fails even when the value is
    // genuinely unchanged. phoneE164 and email are the real account-takeover guards.
    // This is the primary defence against account-takeover via phone-claim attacks
    // (cf. security review C1 / C2).
    match /users/{uid} {
      // `id` is not stored as a document field (it is the document path), so
      // never include it in field-level checks. `isSelf(uid)` already binds the
      // path wildcard to the authenticated user's uid.
      function isUserUpdateSafe() {
        // Use .get() with a sentinel default for phoneE164 because dot-notation on an
        // absent field does not compare equal to null in Firestore rules — only .get()
        // guarantees a safe fallback that makes null==null evaluate to true.
        return request.resource.data.get('phoneE164', '__absent__') == resource.data.get('phoneE164', '__absent__')
          && request.resource.data.email == resource.data.email;
      }
      // Email-only accounts must not carry a phoneE164 field on create — phone
      // numbers are written exclusively by Cloud Functions (admin SDK, bypasses
      // these rules). The path-level isSelf(uid) guard already ensures the user
      // can only write their own document.
      function isUserCreateSafe() {
        return !('phoneE164' in request.resource.data);
      }

      allow read: if signedIn();
      allow create: if isAdmin() || (isSelf(uid) && isUserCreateSafe());
      allow update: if isAdmin() || (isSelf(uid) && isUserUpdateSafe());
      allow delete: if isAdmin();
    }

    // ---------- PROVIDERS (public read, owner write) ----------
    match /providers/{uid} {
      allow read: if true;
      allow create: if isAdmin() || isSelf(uid);
      allow update: if isAdmin() || isSelf(uid);
      allow delete: if isAdmin();
    }

    // ---------- BLOCKED SLOTS (provider availability) ----------
    match /providers/{uid}/blocked_slots/{slotId} {
      allow read: if signedIn();
      allow create, update: if isAdmin() || isSelf(uid);
      allow delete: if isAdmin() || isSelf(uid);
    }

    // ---------- SERVICE TYPES (reference collection) ----------
    match /service_types/{typeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- SERVICES (public read) ----------
    match /services/{serviceId} {
      allow read: if true;

      // Create by owner provider
      allow create: if isAdmin()
        || (signedIn() && request.resource.data.providerId == request.auth.uid);

      // Update by owner; providerId immutable
      allow update: if isAdmin()
        || (signedIn()
            && resource.data.providerId == request.auth.uid
            && request.resource.data.providerId == resource.data.providerId);

      allow delete: if isAdmin()
        || (signedIn() && resource.data.providerId == request.auth.uid);
    }

    // ---------- BOOKINGS (private) ----------
    // Note: isBookingParticipant() is NOT used here — it calls get() on the
    // booking document itself (circular reference), which Firestore denies for
    // both get and list. Use resource.data directly instead.
    match /bookings/{bookingId} {
      function isParticipant() {
        return signedIn()
          && (resource.data.customerId == request.auth.uid
              || resource.data.providerId == request.auth.uid);
      }

      allow get: if isAdminOrModerator() || isParticipant();
      allow list: if isAdminOrModerator() || isParticipant();

      // Create: customer creates; status must start as "requested"
      allow create: if isAdmin()
        || (signedIn()
            && request.resource.data.customerId == request.auth.uid
            && request.resource.data.status == "requested");

      // Update: participants may update non-status fields only.
      // Status is immutable from client — all transitions via Cloud Functions.
      allow update: if isAdmin()
        || (isParticipant()
            && request.resource.data.customerId == resource.data.customerId
            && request.resource.data.providerId == resource.data.providerId
            && request.resource.data.serviceId == resource.data.serviceId
            && request.resource.data.status == resource.data.status);

      allow delete: if isAdmin();
    }

    // ---------- CHATS (private to participants) ----------
    match /chats/{chatId} {
      function isChatParticipant() {
        return signedIn()
          && (request.auth.uid in resource.data.participantIds);
      }

      allow read: if isAdminOrModerator() || isChatParticipant();

      // Chat documents are created exclusively by the acceptBooking Cloud Function.
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        // isChatParticipant() uses resource which refers to the message doc (not the chat).
        // For messages we must get() the parent chat document explicitly.
        function isParticipantViaChat() {
          return signedIn()
            && (request.auth.uid in
                get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds);
        }

        allow read: if isAdminOrModerator() || isParticipantViaChat();

        // Create: only participants; senderId must match auth uid
        // text OR mediaUrl must be present (supports image/voice messages)
        allow create: if isAdmin()
          || (isParticipantViaChat()
              && request.resource.data.senderId == request.auth.uid
              && request.resource.data.createdAt is timestamp
              && (request.resource.data.text is string
                  || request.resource.data.mediaUrl is string));

        // Read receipt update: participants may only append their own uid to readBy.
        allow update: if isAdmin()
          || (isParticipantViaChat()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
              && request.auth.uid in request.resource.data.readBy);

        allow delete: if isAdmin();
      }

      // ---------- TYPING INDICATORS ----------
      // Each user writes their own doc (uid == auth.uid).
      // Read is open to any chat participant.
      // Abuse risk: negligible — one tiny doc per participant, no data exposed.
      match /typing/{uid} {
        function isParticipantViaChatForTyping() {
          return signedIn()
            && (request.auth.uid in
                get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds);
        }

        allow read: if isAdminOrModerator() || isParticipantViaChatForTyping();
        allow write: if isParticipantViaChatForTyping()
          && request.auth.uid == uid
          && request.resource.data.keys().hasOnly(['updatedAt'])
          && request.resource.data.updatedAt is timestamp;
        allow delete: if isParticipantViaChatForTyping() && request.auth.uid == uid;
      }
    }

    // ---------- PHONE SHARE (unlock after accept or beyond) ----------
    match /bookings/{bookingId}/phoneShares/{uid} {
      allow read: if isAdmin()
        || (isBookingParticipant(bookingId) && bookingAccessible(bookingId));

      allow create: if isAdmin()
        || (isBookingParticipant(bookingId)
            && isSelf(uid)
            && bookingAccessible(bookingId)
            && request.resource.data.phone is string
            && request.resource.data.phone.matches('^\\+[1-9][0-9]{6,14}$')
            && request.resource.data.createdAt is timestamp);

      allow update: if isAdmin()
        || (isBookingParticipant(bookingId)
            && isSelf(uid)
            && bookingAccessible(bookingId)
            && request.resource.data.phone is string
            && request.resource.data.phone.matches('^\\+[1-9][0-9]{6,14}$'));

      allow delete: if isAdmin();
    }

    // ---------- REVIEWS ----------
    // Reviews are only allowed after a booking reaches "done" status.
    // Reviewer must be a participant of the referenced booking.
    match /reviews/{reviewId} {
      allow read: if signedIn();

      // Create-only (no non-admin update) + deterministic doc id
      // "{bookingId}_{reviewerId}" guarantees one review per (booking, reviewer):
      // a second attempt targets an existing doc → update → denied.
      // revieweeId must be the OTHER booking participant (no self-review).
      allow create: if signedIn()
        && reviewId == request.resource.data.bookingId + '_' + request.auth.uid
        && request.resource.data.reviewerId == request.auth.uid
        && request.resource.data.bookingId is string
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && bookingExists(request.resource.data.bookingId)
        && bookingData(request.resource.data.bookingId).status == "done"
        && (
          (bookingData(request.resource.data.bookingId).customerId == request.auth.uid
            && request.resource.data.revieweeId == bookingData(request.resource.data.bookingId).providerId)
          || (bookingData(request.resource.data.bookingId).providerId == request.auth.uid
            && request.resource.data.revieweeId == bookingData(request.resource.data.bookingId).customerId)
        );

      allow update, delete: if isAdmin();
    }

    // ---------- REPORTS (any signed-in user can create, support+ read) ----------
    match /reports/{reportId} {
      allow read: if isMinSupport();
      allow create: if signedIn();
      allow update: if isMinSupport();
      allow delete: if isAdmin();
    }

    // ---------- USER ROLES (admin visibility on privileged accounts) ----------
    match /user_roles/{uid} {
      allow read: if isReadonly();
      allow write: if false; // written exclusively by Cloud Functions (Admin SDK)
    }

    // ---------- MODERATION QUEUE (pre-publication review) ----------
    match /moderation_queue/{docId} {
      allow read: if isMinSupport();
      allow write: if false; // written exclusively by Cloud Functions (Admin SDK)
    }

    // ---------- USER BANS (ban/suspend/shadow-ban records) ----------
    match /user_bans/{userId} {
      allow read: if isMinSupport();
      allow write: if false; // written exclusively by Cloud Functions (Admin SDK)
    }

    // ---------- ADMIN LOGS (audit trail, moderator+ read) ----------
    match /admin_logs/{logId} {
      allow read: if isReadonly();
      allow write: if false; // written exclusively by Cloud Functions (Admin SDK)
    }

    // ---------- NOTIFICATIONS (private to owner) ----------
    match /notifications/{uid}/items/{notifId} {
      allow read: if isSelf(uid);

      // Only Cloud Functions (admin SDK) may create notifications.
      allow create: if isAdmin();

      // Owner may only flip the 'read' field.
      allow update: if isSelf(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      allow delete: if isAdmin() || isSelf(uid);
    }

    // ---------- USER SESSIONS (staff read-only, written by Cloud Functions) ----------
    match /user_sessions/{uid} {
      allow read: if isReadonly();
      allow write: if false; // written exclusively by Cloud Functions (Admin SDK)

      match /events/{eventId} {
        allow read: if isReadonly();
        allow write: if false;
      }
    }

    // Collection group rule required for collectionGroup('events') queries.
    // Without this, Firestore rejects the query even if the nested rule exists.
    match /{path=**}/events/{eventId} {
      allow read: if isReadonly();
      allow write: if false;
    }

    // ---------- IP GEO CACHE (admin read-only, CF write-only) ----------
    match /ip_geo_cache/{hash} {
      allow read: if isAdmin();
      allow write: if false; // written exclusively by Cloud Functions (Admin SDK)
    }

    // ---------- Default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
