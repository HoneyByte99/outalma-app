rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && request.auth.token.admin == true; }
    function isSelf(uid) { return signedIn() && request.auth.uid == uid; }

    function bookingDoc(bookingId) {
      return firestore.get(/databases/(default)/documents/bookings/$(bookingId));
    }
    function bookingExists(bookingId) {
      return firestore.exists(/databases/(default)/documents/bookings/$(bookingId));
    }
    function bookingData(bookingId) {
      return bookingDoc(bookingId).data;
    }
    function isBookingParticipant(bookingId) {
      return signedIn()
        && bookingExists(bookingId)
        && (bookingData(bookingId).customerId == request.auth.uid
            || bookingData(bookingId).providerId == request.auth.uid);
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }
    function smallEnough(maxBytes) {
      return request.resource.size < maxBytes;
    }

    // Public service images
    // Path: /public/services/{serviceId}/{filename}
    // Write restricted to the provider who owns the service document.
    // This prevents arbitrary uploads to other providers' service paths.
    // Service images are uploaded under the uploader's uid segment so writes
    // authorise via isSelf(uid) — NO cross-service firestore.get (those silently
    // fail from Storage in this project, which is why the previous doc-ownership
    // rule denied legitimate uploads). This also works during the new-service
    // flow, before the Firestore service doc exists. The photo URLs are stored
    // on the service doc, whose write access is gated by Firestore rules
    // (provider-owner only), so uid-scoping here is sufficient.
    // Path: /public/services/{serviceId}/{uid}/{filename}
    match /public/services/{serviceId}/{uid}/{filename} {
      allow read: if true;
      allow write: if isAdmin() || (
        isSelf(uid)
        && isImage()
        && smallEnough(5 * 1024 * 1024)
      );
    }

    // Legacy single-level service image path (pre uid-scoping). Public read for
    // already-uploaded photos; new uploads use the uid-scoped path above.
    match /public/services/{serviceId}/{filename} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User avatars
    // Path: /private/users/{uid}/avatar/{filename}
    // Read is open to any authenticated user so chat participants can display
    // each other's profile photos. Write is restricted to the owner.
    match /private/users/{uid}/avatar/{filename} {
      allow read: if signedIn();
      allow write: if isAdmin() || (isSelf(uid) && isImage() && smallEnough(5 * 1024 * 1024));
    }

    // Chat media (images + voice messages)
    // Path: /private/chats/{chatId}/media/{uid}/{filename}
    // Scoped by uploader uid so writes authorize via isSelf(uid) — NO
    // cross-service firestore.get (that lookup silently fails from Storage and
    // denied legitimate participants). The recipient plays media via the
    // tokenised download URL stored on the chat message, so read stays simple:
    // any signed-in user with the (unguessable, tokenised) URL.
    match /private/chats/{chatId}/media/{uid}/{filename} {
      allow read: if signedIn();
      allow write: if isAdmin() || (
        isSelf(uid)
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('audio/.*'))
        && smallEnough(20 * 1024 * 1024)
      );
    }

    // Legacy chat media path (pre-uid-scoping). Read-only for backward compat
    // with already-uploaded objects; new uploads use the uid-scoped path above.
    match /private/chats/{chatId}/media/{filename} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Booking request voice messages, uploaded BEFORE the booking exists
    // (no bookingId yet), so they are scoped by uploader uid instead.
    // Path: /private/bookings/voice/{uid}/{filename}
    // The provider plays the message via the tokenised download URL stored on
    // the booking document, so read can stay owner-only.
    match /private/bookings/voice/{uid}/{filename} {
      allow read: if isAdmin() || isSelf(uid);
      allow write: if isAdmin()
        || (isSelf(uid)
            && request.resource.contentType.matches('audio/.*')
            && smallEnough(20 * 1024 * 1024));
    }

    // Booking attachments (private to participants)
    // Path: /private/bookings/{bookingId}/attachments/{filename}
    match /private/bookings/{bookingId}/attachments/{filename} {
      allow read: if isAdmin() || isBookingParticipant(bookingId);
      allow write: if isAdmin()
        || (isBookingParticipant(bookingId)
            && (request.resource.contentType.matches('image/.*')
                || request.resource.contentType.matches('application/pdf'))
            && smallEnough(20 * 1024 * 1024));
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
