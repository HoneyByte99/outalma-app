{
  "name": "outalma-functions",
  "private": true,
  "version": "0.1.0",
  "main": "lib/index.js",
  "type": "commonjs",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json",
    "lint": "eslint --max-warnings=0 .",
    "lint:fix": "eslint --fix .",
    "test": "firebase emulators:exec --only firestore --project demo-outalma --config firebase.emulator.json \"jest --runInBand --forceExit\"",
    "serve": "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^12.1.0",
    "firebase-functions": "^7.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.15",
    "eslint": "^9.17.0",
    "firebase-functions-test": "^3.5.0",
    "globals": "^15.13.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.0"
  }
}
