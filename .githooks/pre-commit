#!/bin/sh
# Quality gate mirroring CI + the project testing bar (.claude/rules/testing-bar.md):
#   0. secret scan on the staged diff (always on; .githooks/ excluded)
#   1. dart format check (mirrors CI "Check formatting")
#   2. functions tsc build when functions/*.ts is staged (mirrors CI functions job)
#   3. flutter analyze --fatal-warnings (mirrors CI "Analyze")
#   4. full test suite (regression gate, mirrors CI "Test")
#   5. >= 90% line coverage on staged critical-layer files
#      (lib/src/{domain,data,application}; structural exemptions in
#      .githooks/coverage-exempt)
#
# Steps 3-5 only run when lib/ or test/ Dart files are staged.
# Bypass once:  OUTALMA_SKIP_GATE=1 git commit ...   (keeps secret scan + format)
#               git commit --no-verify              (skips everything)
#
# One-time setup per clone:
#   git config core.hooksPath .githooks

staged_all=$(git diff --cached --name-only --diff-filter=ACMR)
[ -z "$staged_all" ] && exit 0

# ── 0. Secret scan — ALL staged files, runs even with OUTALMA_SKIP_GATE ──────
# Scans only the ADDED lines of the staged diff, so legacy occurrences in the
# tree never block. Override requires the explicit git escape: --no-verify.
secrets=$(git diff --cached -U0 --diff-filter=ACMR -- . ':(exclude).githooks' \
  | grep '^+' | grep -v '^+++' \
  | grep -nE 'AIza[0-9A-Za-z_-]{35}|-----BEGIN [A-Z ]*PRIVATE KEY|AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36}|github_pat_[A-Za-z0-9_]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}|ya29\.[A-Za-z0-9_-]{20,}|"private_key" *:' \
  || true)
if [ -n "$secrets" ]; then
  printf '%s\n' "$secrets" | head -5
  echo ""
  echo "Commit blocked: staged diff appears to contain a secret or API key."
  echo "Move it to a gitignored config / environment variable. If this is a"
  echo "false positive, bypass once with:  git commit --no-verify"
  exit 1
fi

staged_dart=$(printf '%s\n' "$staged_all" | grep '\.dart$' || true)
staged_fn_ts=$(printf '%s\n' "$staged_all" | grep -E '^functions/.*\.ts$' || true)

# ── 1. Format ────────────────────────────────────────────────────────────────
if [ -n "$staged_dart" ]; then
  if ! dart format --output=none --set-exit-if-changed $staged_dart; then
    echo ""
    echo "Commit blocked: unformatted Dart files (listed above)."
    echo "Fix with:  dart format lib/ test/   then re-stage and commit."
    exit 1
  fi
fi

[ "$OUTALMA_SKIP_GATE" = "1" ] && exit 0

out=$(mktemp)
trap 'rm -f "$out"' EXIT

# ── 2. Functions build (tsc) ─────────────────────────────────────────────────
# Fast (~5s) type-check so a half-finished functions change can never land.
# The full emulator-backed jest suite runs in CI (too slow per-commit).
if [ -n "$staged_fn_ts" ]; then
  echo "pre-commit: functions tsc..."
  if ! (cd functions && npm run build) > "$out" 2>&1; then
    tail -25 "$out"
    echo "Commit blocked: functions TypeScript does not compile."
    exit 1
  fi
fi

code_changed=$(printf '%s\n' "$staged_dart" | grep -E '^(lib|test)/' || true)
[ -z "$code_changed" ] && exit 0

# ── 3. Analyze ───────────────────────────────────────────────────────────────
echo "pre-commit: flutter analyze..."
if ! flutter analyze --fatal-warnings > "$out" 2>&1; then
  cat "$out"
  echo "Commit blocked: flutter analyze failed."
  exit 1
fi

# ── 4. Tests (regression gate) ───────────────────────────────────────────────
echo "pre-commit: flutter test --coverage..."
if ! flutter test --coverage > "$out" 2>&1; then
  tail -40 "$out"
  echo "Commit blocked: tests failed."
  exit 1
fi

# ── 5. Coverage bar on staged critical-layer files ───────────────────────────
critical=$(printf '%s\n' "$staged_dart" | grep -E '^lib/src/(domain|data|application)/' || true)
fail=0
for f in $critical; do
  grep -qxF "$f" .githooks/coverage-exempt 2>/dev/null && continue
  # Pure contracts (abstract repositories) have no executable lines.
  case "$f" in lib/src/domain/repositories/*) continue ;; esac
  pct=$(awk -F: -v f="$f" '
    $1=="SF" && $2==f {hit=1}
    hit && $1=="LF" {lf=$2}
    hit && $1=="LH" {lh=$2}
    hit && /^end_of_record/ {exit}
    END {if (lf>0) printf "%d", 100*lh/lf; else if (hit) print 100; else print -1}
  ' coverage/lcov.info)
  if [ "$pct" -lt 0 ]; then
    echo "COVERAGE  $f: not exercised by any test (0%)"
    fail=1
  elif [ "$pct" -lt 90 ]; then
    echo "COVERAGE  $f: ${pct}% (< 90%)"
    fail=1
  fi
done

if [ "$fail" = "1" ]; then
  echo ""
  echo "Commit blocked: staged critical-layer files are below the 90% coverage bar."
  echo "Add tests for the files above, or bypass once with:"
  echo "  OUTALMA_SKIP_GATE=1 git commit ..."
  echo "(Structural exemptions: .githooks/coverage-exempt)"
  exit 1
fi

exit 0
